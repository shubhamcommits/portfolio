# Email configuration for contact form
RESEND_API_KEY=your_resend_api_key_here
CONTACT_EMAIL=your_email@example.com

# Site URL (used for metadata, sitemaps, and OG images)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Visitor analytics (Phase 1 + 2)
# Vercel Postgres / Neon: auto-injected by the Vercel Marketplace integration
DATABASE_URL=postgres://...

# IPinfo token for IP-to-company enrichment (free 50k/mo at https://ipinfo.io)
IPINFO_TOKEN=your_ipinfo_token

# Salt used to hash visitor fingerprints. Change to invalidate existing IDs.
ANALYTICS_SALT=change-me-to-anything-random

# Admin dashboard auth
ADMIN_EMAIL=you@example.com
ADMIN_SECRET=long-random-string-used-for-cookie-signing-and-init-route
